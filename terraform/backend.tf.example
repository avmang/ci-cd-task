# Example backend configuration for Terraform state management
# Copy this file to backend.tf and update with your values

# Create a GCS bucket first:
# gsutil mb -p YOUR_PROJECT_ID -l us-central1 gs://YOUR_BUCKET_NAME-tfstate

terraform {
  backend "gcs" {
    bucket = "your-project-tfstate"  # Replace with your bucket name
    prefix = "terraform/state"
  }
}
